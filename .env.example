# Copy to .env and fill in real values

# MCP Configuration
# Set to "true" to use manual MCP server startup mode (recommended)
# When enabled, start servers manually before running LangGraph:
# Terminal 1: FIRECRAWL_API_KEY=your-key npx -y firecrawl-mcp
# Terminal 2: REPLICATE_API_TOKEN=your-token npx -y replicate-mcp
MANUAL_MCP_MODE=false

# Firecrawl SSE Configuration
# Set to "true" to use SSE mode for Firecrawl MCP (recommended)
# Option 1: Use Firecrawl's hosted SSE endpoint (no local server needed)
FIRECRAWL_SSE_MODE=true
FIRECRAWL_SSE_URL=https://mcp.firecrawl.dev/YOUR_API_KEY/sse

# Option 2: Local SSE server (if supported by your firecrawl-mcp version)
# FIRECRAWL_SSE_URL=http://localhost:3000/sse
# When enabled, start SSE server manually:
# env SSE_LOCAL=true FIRECRAWL_API_KEY=your-key npx -y firecrawl-mcp

# Tavily (for web search tool in the example)
TAVILY_API_KEY=

# Firecrawl MCP
FIRECRAWL_API_KEY=
# By default we attempt to use the official MCP server via npx
FIRECRAWL_MCP_COMMAND=npx
FIRECRAWL_MCP_ARGS=-y firecrawl-mcp

# Replicate MCP
REPLICATE_API_TOKEN=
# By default we attempt to use the official MCP server via npx
REPLICATE_MCP_COMMAND=npx
REPLICATE_MCP_ARGS=-y replicate-mcp

# Supabase (Edge Functions & Storage)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_UPLOADS_BUCKET=context-uploads

# OpenAI for embeddings (used by Edge Functions)
OPENAI_API_KEY=

# Unstructured processing (optional; used by ingest_upload)
UNSTRUCTURED_API_KEY=
UNSTRUCTURED_URL=https://api.unstructuredapp.io/general/v0/general
USE_UNSTRUCTURED=true
USE_EMBEDDINGS=true