# Copy to .env and fill in real values

# Tavily (for web search tool in the example)
TAVILY_API_KEY=

# Firecrawl MCP
FIRECRAWL_API_KEY=
# By default we attempt to use the official MCP server via npx
FIRECRAWL_MCP_COMMAND=npx
FIRECRAWL_MCP_ARGS=-y @modelcontextprotocol/server-firecrawl

# Replicate MCP
REPLICATE_API_TOKEN=
# By default we attempt to use the official MCP server via npx
REPLICATE_MCP_COMMAND=npx
REPLICATE_MCP_ARGS=-y @modelcontextprotocol/server-replicate